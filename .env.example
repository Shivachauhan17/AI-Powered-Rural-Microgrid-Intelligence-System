# Copy to .env and fill in values

# App
SOLAR_CAPACITY_KW=30.0
BATTERY_CAPACITY_KWH=50.0
TOTAL_HOUSES=10
LOG_LEVEL=INFO
ENVIRONMENT=production
DEBUG=false
BACKEND_CORS_ORIGINS=["http://localhost","http://YOUR_EC2_IP"]

# S3 — leave blank for local development
MODEL_S3_BUCKET=
MODEL_S3_PREFIX=models/latest/

# Twilio — leave blank to simulate SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
