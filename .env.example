# ── AI Microgrid System - Environment Variables ──────────────────
# Copy this file to .env and fill in your values

# App
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
DEBUG=false

# Microgrid Config
SOLAR_CAPACITY_KW=30.0
BATTERY_CAPACITY_KWH=50.0
BATTERY_INITIAL_SOC=0.6
TOTAL_HOUSES=10

# AWS
AWS_REGION=ap-south-1
AWS_S3_BUCKET=microgrid-data
AWS_IOT_ENDPOINT=

# Redis
REDIS_URL=redis://redis:6379/0

# Twilio SMS (optional - for operator alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Database
DATABASE_URL=sqlite:///./microgrid.db
